rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Bootstrapped admin
      return isSignedIn() && request.auth.token.email == 'hcmc.duyvo@gmail.com' && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidPost(data) {
      return data.keys().hasAll(['title', 'slug', 'excerpt', 'content', 'date', 'author', 'tags', 'readTime']) &&
             data.keys().size() == 8 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() <= 250 &&
             data.excerpt is string && data.excerpt.size() <= 1000 &&
             data.content is string && data.content.size() <= 50000 &&
             data.date is string && data.date.size() > 0 && data.date.size() <= 50 &&
             data.author is string && data.author.size() > 0 && data.author.size() <= 100 &&
             data.tags is list && data.tags.size() <= 20 && (data.tags.size() == 0 || (data.tags.size() > 0 && data.tags[0] is string)) &&
             data.readTime is number && data.readTime > 0;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['author', 'text', 'date', 'postId']) &&
             data.keys().size() == 4 &&
             data.author is string && data.author.size() > 0 && data.author.size() <= 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 2000 &&
             data.date is string && data.date.size() > 0 && data.date.size() <= 50 &&
             data.postId is string && data.postId.size() > 0 && data.postId.size() <= 128;
    }

    match /posts/{postId} {
      allow get: if isValidId(postId);
      allow list: if true; // Public read
      allow create: if isAdmin() && isValidId(postId) && isValidPost(incoming());
      // Admin update can change any field, as long as it validates.
      // Easiest is to require full validation, or allow specific keys.
      allow update: if isAdmin() && isValidId(postId) && isValidPost(incoming()) && (
        true
      );
      allow delete: if isAdmin() && isValidId(postId);
      
      match /comments/{commentId} {
        allow get: if isValidId(postId) && isValidId(commentId);
        allow list: if isValidId(postId);
        // Anyone can create a comment if they provide the right format
        // Wait, does the commenter need to be signed in?
        // App currently allows anonymous comments (using the simulated 3rd party comments UI)
        allow create: if isValidId(postId) && isValidId(commentId) && isValidComment(incoming()) && incoming().postId == postId;
        allow update, delete: if isAdmin() && isValidId(postId) && isValidId(commentId);
      }
    }
  }
}
